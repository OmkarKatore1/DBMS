CREATE VIEW Student_Course_View AS
SELECT s.name, c.cname, e.marks
FROM Students s
JOIN Enrollments e ON s.s_id = e.s_id
JOIN Courses c ON e.c_id = c.c_id;


CREATE VIEW High_Marks_View AS
SELECT * FROM Student_Course_View
WHERE marks > 75;


