SET SERVEROUTPUT ON;
DECLARE
    CURSOR c1 IS 
        SELECT name, SUM(amt) AS total
        FROM orders
        GROUP BY name;
    v_name orders.name%TYPE;
    v_total NUMBER;
BEGIN
    OPEN c1;
    LOOP
        FETCH c1 INTO v_name, v_total;
        EXIT WHEN c1%NOTFOUND;
        INSERT INTO customer_total VALUES (v_name, v_total);
        DBMS_OUTPUT.PUT_LINE('Customer: ' || v_name || 
                             ' Total: ' || v_total);
    END LOOP;
    CLOSE c1;
SELECT * FROM customer_total;

END;
